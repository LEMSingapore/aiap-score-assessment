# Virtual environments
.venv/
venv/
env/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
*.pkl

# Jupyter
.ipynb_checkpoints/

# OS / editor
.DS_Store
.vscode/
.idea/

# Data and artifacts (do not commit large or private files)
data/*.db
data/*.sqlite
data/*.sqlite3
data/*.csv
data/*.parquet
data/*.xlsx

# Artifacts — ignore build outputs by default,
# but track lightweight provenance files for assessor inspection
artifacts/*
!artifacts/best_model_metadata.json
!artifacts/model_comparison.csv

# Logs
logs/
*.log

# Large build output — regenerable via ./run.sh
artifacts/best_model.joblib
